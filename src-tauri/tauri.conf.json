{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Auto Judge",
  "version": "0.1.0",
  "identifier": "cn.aidl.autojudge",
  "build": {
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Auto Judge",
        "width": 1440,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "backgroundColor": "#f5f7fb"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/1024x1024.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../ds_lz": "ds_lz"
    }
  }
}
